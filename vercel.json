{
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/",         "destination": "/api/home" },
    { "source": "/(.*)",     "destination": "/public/$1" }
  ],
  "functions": {
    "api/stripe-webhook.js": { "maxDuration": 10 },
    "api/buyers-brief.js":   { "maxDuration": 60 }
  }
}
