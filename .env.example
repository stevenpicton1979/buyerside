# ─── BuyerSide Environment Variables ───
# Copy this file to .env.local for local development
# Add all of these to Vercel Dashboard → Settings → Environment Variables for production

# ─── ANTHROPIC ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── STRIPE ───
STRIPE_SECRET_KEY=sk_live_...          # Use sk_test_... for development
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe Dashboard → Webhooks

# ─── SUPABASE ───
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...            # Service role key (not anon key — has write access)

# ─── DOMAIN API ───
DOMAIN_API_KEY=key_...                 # From developer.domain.com.au

# ─── RESEND (email) ───
RESEND_API_KEY=re_...                  # From resend.com

# ─── APP ───
BASE_URL=https://buyerside.com.au      # Use http://localhost:3000 for local dev
ALLOWED_ORIGIN=https://buyerside.com.au  # CORS — use * for development

# ─── PROPTECH DATA ───
# Add once you have access from PropTechData sales conversation
# PROPTECH_DATA_API_KEY=...

# ─── OPTIONAL ───
NODE_ENV=production                    # Set to 'development' locally
