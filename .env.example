# ─── ClearOffer Environment Variables ───
# Copy this file to .env.local for local development
# To run locally: doppler run -- npm run dev
# All production secrets managed via Doppler — do not hardcode or commit secrets.

# ─── ANTHROPIC ───
ANTHROPIC_API_KEY=sk-ant-...

# ─── STRIPE ───
STRIPE_SECRET_KEY=sk_test_...          # Use sk_test_... for development, sk_live_... for production
STRIPE_WEBHOOK_SECRET=whsec_...        # From Stripe Dashboard → Webhooks

# ─── SUPABASE ───
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...            # Service role key (not anon key — has write access)

# ─── RESEND (email) ───
RESEND_API_KEY=re_...                  # From resend.com

# ─── ZONEIQ ───
ZONEIQ_URL=https://zoneiq-sigma.vercel.app

# ─── APP ───
BASE_URL=https://clearoffer.com.au      # Use http://localhost:3000 for local dev
ALLOWED_ORIGIN=https://clearoffer.com.au  # CORS — use * for development

# ─── GOOGLE GEOCODING ───
# For future address search upgrade — not used in v1 (Nominatim handles autocomplete until Domain API approved)
# GOOGLE_GEOCODING_API_KEY=

# ─── OPTIONAL ───
NODE_ENV=production                    # Set to 'development' locally

# ─── Pending API approval ───

# Domain developer API — active listing data only (not sold/AVM data).
# Domain Insights/Pricefinder VG restriction does not apply to the developer API.
# Approval pending at developer.domain.com.au (Address Suggestions, Agents & Listings,
# Price Estimation, Properties & Locations).
# Active listing data: listing price, beds/baths, days on market, agent name, photos.
DOMAIN_CLIENT_ID=...
DOMAIN_CLIENT_SECRET=...
DOMAIN_API_KEY=key_...

# ─── PROPTECH DATA ───
# Add once credentials received from PropTechData (hello@proptechdata.com.au)
# PROPTECH_DATA_API_KEY=...
